{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "toolchainFile": "$penv{GLOBAL_VCPKG_PATH}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "ARC_QT6_BUILD": true,
        "DEV_MODE": false,
        "USE_QLITEHTML": true
      },
      "warnings": {
        "dev": false
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": ["base"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "FASTBuild",
      "environment": {
        "PATH": "$penv{WindowsKitRC};$penv{PATH}",
        "FASTBUILD_CACHE_PATH": "$penv{LOCALAPPDATA}/FASTBuild/Cache"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_MSVC_DEBUG_INFORMATION_FORMAT": "Embedded"
      },
      "vendor": {
        "arcforges.org": {
          "vcpkgTriplet": "x64-windows"
        }
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows x64 Debug",
      "description": "FASTBuild Debug build with Qt6",
      "inherits": ["windows-base"],
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows x64 Release",
      "description": "FASTBuild Release build with Qt6",
      "inherits": ["windows-base"],
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "windows-debug",
      "displayName": "Debug",
      "nativeToolOptions": ["-cache", "-summary"],
      "targets": ["all"]
    },
    {
      "name": "release",
      "configurePreset": "windows-release",
      "displayName": "Release",
      "nativeToolOptions": ["-cache", "-summary"],
      "targets": ["all"]
    }
  ]
}
