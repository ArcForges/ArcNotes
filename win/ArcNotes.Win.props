<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ArcNotesRoot>$(MSBuildThisFileDirectory)..\</ArcNotesRoot>
    <ArcNotesSrcRoot>$(ArcNotesRoot)src\</ArcNotesSrcRoot>
    <ArcNotesBuildFlavor Condition="'$(Configuration)' == 'Release'">release</ArcNotesBuildFlavor>
    <ArcNotesBuildFlavor Condition="'$(ArcNotesBuildFlavor)' == ''">debug</ArcNotesBuildFlavor>
    <OutDir>$(ArcNotesRoot)build\$(ArcNotesBuildFlavor)\bin\</OutDir>
    <IntDir>$(ArcNotesRoot)build\windows-msbuild\obj\$(MSBuildProjectName)\$(Configuration)\$(Platform)\</IntDir>
    <TargetExt>.exe</TargetExt>
    <QtDir Condition="'$(QtDir)' == ''">$(QT_DIR)</QtDir>
    <QtBinDir>$(QtDir)\bin</QtBinDir>
    <QtLibDir>$(QtDir)\lib</QtLibDir>
    <QtIncludeRoot>$(QtDir)\include</QtIncludeRoot>
    <QtMkspecDir>$(QtDir)\mkspecs\win32-msvc</QtMkspecDir>
    <QtLibSuffix Condition="'$(Configuration)' == 'Debug'">d</QtLibSuffix>
    <QtMocIntermediateDir>$(IntDir)qt-moc\</QtMocIntermediateDir>
    <QtUicIntermediateDir>$(IntDir)qt-uic\</QtUicIntermediateDir>
    <QtRccIntermediateDir>$(IntDir)qt-rcc\</QtRccIntermediateDir>
    <ProgramDatabaseFile>$(OutDir)$(TargetName).pdb</ProgramDatabaseFile>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <SDLCheck>true</SDLCheck>
      <MultiProcessorCompilation>true</MultiProcessorCompilation>
      <ConformanceMode>true</ConformanceMode>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <ExternalWarningLevel>TurnOffAllWarnings</ExternalWarningLevel>
      <AdditionalOptions>/Zc:__cplusplus /utf-8 /external:anglebrackets /wd4100 %(AdditionalOptions)</AdditionalOptions>
      <PreprocessorDefinitions>UNICODE;_UNICODE;NOMINMAX;_CRT_SECURE_NO_WARNINGS;QAPPLICATION_CLASS=QApplication;FAKEVIM_STATIC_DEFINE;QTCREATOR_UTILS_STATIC_LIB;USE_QLITEHTML=1;QLITEHTML_STATIC_LIBRARY;LITEHTML_UTF8;QT_CORE_LIB;QT_GUI_LIB;QT_WIDGETS_LIB;QT_SQL_LIB;QT_SVG_LIB;QT_NETWORK_LIB;QT_XML_LIB;QT_PRINTSUPPORT_LIB;QT_CONCURRENT_LIB;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <PreprocessorDefinitions Condition="'$(Configuration)' == 'Debug'">QT_DEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(ArcNotesSrcRoot);$(ArcNotesSrcRoot)libraries\qtcsv\src;$(ArcNotesSrcRoot)libraries\qlitehtml\src;$(ArcNotesSrcRoot)libraries\qlitehtml\src\3rdparty\litehtml\include;$(ArcNotesSrcRoot)libraries\qlitehtml\src\3rdparty\litehtml\include\litehtml;$(ArcNotesSrcRoot)libraries\qlitehtml\src\3rdparty\litehtml\src;$(ArcNotesSrcRoot)libraries\qlitehtml\src\3rdparty\litehtml\src\gumbo\include;$(ArcNotesSrcRoot)libraries\qlitehtml\src\3rdparty\litehtml\src\gumbo\include\gumbo;$(ArcNotesSrcRoot)libraries\qlitehtml\src\3rdparty\litehtml\src\gumbo\visualc\include;$(ArcNotesSrcRoot)libraries\fakevim;$(ArcNotesSrcRoot)libraries\fakevim\fakevim;$(ArcNotesSrcRoot)libraries\qhotkey\QHotkey;$(ArcNotesSrcRoot)libraries\qmarkdowntextedit;$(ArcNotesSrcRoot)libraries\md4c\src;$(ArcNotesSrcRoot)libraries\qttoolbareditor\src;$(ArcNotesSrcRoot)libraries\singleapplication;$(ArcNotesSrcRoot)libraries\qkeysequencewidget\qkeysequencewidget\src;$(ArcNotesSrcRoot)libraries\fuzzy;$(ArcNotesSrcRoot)libraries\diff_match_patch;$(QtMocIntermediateDir);$(QtUicIntermediateDir);$(QtRccIntermediateDir);$(QtIncludeRoot);$(QtIncludeRoot)\QtCore;$(QtIncludeRoot)\QtGui;$(QtIncludeRoot)\QtWidgets;$(QtIncludeRoot)\QtSql;$(QtIncludeRoot)\QtSvg;$(QtIncludeRoot)\QtNetwork;$(QtIncludeRoot)\QtXml;$(QtIncludeRoot)\QtPrintSupport;$(QtIncludeRoot)\QtConcurrent;$(QtMkspecDir);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <RuntimeLibrary Condition="'$(Configuration)' == 'Debug'">MultiThreadedDebugDLL</RuntimeLibrary>
      <RuntimeLibrary Condition="'$(Configuration)' != 'Debug'">MultiThreadedDLL</RuntimeLibrary>
      <TreatWarningAsError Condition="'$(TreatWarningsAsErrors)' == 'true'">true</TreatWarningAsError>
    </ClCompile>
    <Link>
      <AdditionalLibraryDirectories>$(QtLibDir);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>Qt6Core$(QtLibSuffix).lib;Qt6Gui$(QtLibSuffix).lib;Qt6Widgets$(QtLibSuffix).lib;Qt6Sql$(QtLibSuffix).lib;Qt6Svg$(QtLibSuffix).lib;Qt6Network$(QtLibSuffix).lib;Qt6Xml$(QtLibSuffix).lib;Qt6PrintSupport$(QtLibSuffix).lib;Qt6Concurrent$(QtLibSuffix).lib;Qt6EntryPoint$(QtLibSuffix).lib;%(AdditionalDependencies)</AdditionalDependencies>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <LinkTimeCodeGeneration Condition="'$(Configuration)' == 'Release'">UseLinkTimeCodeGeneration</LinkTimeCodeGeneration>
      <ProgramDatabaseFile>$(ProgramDatabaseFile)</ProgramDatabaseFile>
      <SubSystem>Windows</SubSystem>
    </Link>
  </ItemDefinitionGroup>
</Project>
